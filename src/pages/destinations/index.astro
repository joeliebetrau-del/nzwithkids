---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const destinations = (await getCollection('destinations', ({ data }) => !data.draft))
  .sort((a, b) => b.data.kidRating - a.data.kidRating);
---

<BaseLayout
  title="Where to Take Them"
  description="New Zealand destination guides for families. Every region rated and reviewed for traveling with kids."
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-sm font-semibold text-forest-600 uppercase tracking-wider mb-3">Destination Guides</p>
    <h1 class="font-display text-4xl font-bold text-gray-900 mb-4">Where to Take Them</h1>
    <p class="text-lg text-gray-500 mb-12 leading-relaxed max-w-2xl">
      New Zealand packs a staggering amount into two islands. Here are the regions we know well, rated for families.
    </p>

    {destinations.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {destinations.map((dest) => (
          <a href={`/destinations/${dest.slug}`} class="block border border-gray-200 rounded-xl p-6 hover:border-forest-300 hover:shadow-sm transition-all group">
            <div class="flex items-start justify-between mb-3">
              <p class="text-xs font-semibold text-forest-600 uppercase tracking-wider">{dest.data.region}</p>
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-3 h-3 ${i < dest.data.kidRating ? 'text-forest-500' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <h3 class="font-display text-lg font-bold text-gray-900 mb-2 group-hover:text-forest-700 transition-colors">{dest.data.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{dest.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-gray-400">
        <p class="text-lg">Destination guides coming soon.</p>
      </div>
    )}
  </div>
</BaseLayout>
