---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Real family travel guides for New Zealand. Planning, itineraries, destinations, and honest stories from a family who made the trip.',
  image = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title} | NZ With Kids</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | NZ With Kids`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-white text-gray-800 font-sans antialiased">
    <slot name="header">
      <header class="border-b border-forest-100 bg-white sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-2 text-forest-700 hover:text-forest-900 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span class="font-display text-xl font-semibold tracking-tight">NZ With Kids</span>
            </a>
            <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
              <a href="/planning" class="text-gray-600 hover:text-forest-700 transition-colors">Planning</a>
              <a href="/destinations" class="text-gray-600 hover:text-forest-700 transition-colors">Destinations</a>
              <a href="/itineraries" class="text-gray-600 hover:text-forest-700 transition-colors">Itineraries</a>
              <a href="/blog" class="text-gray-600 hover:text-forest-700 transition-colors">Blog</a>
              <a href="/our-story" class="text-gray-600 hover:text-forest-700 transition-colors">Our Story</a>
            </nav>
            <button id="menu-toggle" class="md:hidden p-2 rounded-md text-gray-600 hover:text-forest-700 focus:outline-none" aria-label="Toggle menu">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
        <!-- Mobile nav -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-forest-100 bg-white">
          <nav class="flex flex-col gap-1 px-4 py-3 text-sm font-medium">
            <a href="/planning" class="py-2 text-gray-600 hover:text-forest-700">Planning</a>
            <a href="/destinations" class="py-2 text-gray-600 hover:text-forest-700">Destinations</a>
            <a href="/itineraries" class="py-2 text-gray-600 hover:text-forest-700">Itineraries</a>
            <a href="/blog" class="py-2 text-gray-600 hover:text-forest-700">Blog</a>
            <a href="/our-story" class="py-2 text-gray-600 hover:text-forest-700">Our Story</a>
          </nav>
        </div>
      </header>
    </slot>

    <main>
      <slot />
    </main>

    <footer class="bg-forest-900 text-forest-100 mt-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-display text-lg font-semibold text-white mb-3">NZ With Kids</h3>
            <p class="text-sm text-forest-300 leading-relaxed">Real family travel guides for New Zealand. We made the trip so you can plan yours with confidence.</p>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Explore</h4>
            <ul class="space-y-2 text-sm text-forest-300">
              <li><a href="/planning" class="hover:text-white transition-colors">Planning Your Trip</a></li>
              <li><a href="/destinations" class="hover:text-white transition-colors">Destinations</a></li>
              <li><a href="/itineraries" class="hover:text-white transition-colors">Itineraries</a></li>
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">About</h4>
            <ul class="space-y-2 text-sm text-forest-300">
              <li><a href="/our-story" class="hover:text-white transition-colors">Our Story</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-8 border-t border-forest-800 text-center text-xs text-forest-500">
          &copy; {new Date().getFullYear()} NZ With Kids. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
